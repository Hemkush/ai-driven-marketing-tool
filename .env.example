# ── Database (Supabase) ────────────────────────────────────────────────────
# Get this from: Supabase → Project Settings → Database → Connection String
# Use the "URI" tab and select "psycopg" (Python) format
DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ── Authentication ─────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
INTERNAL_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Google Places (for Competitive Benchmarking) ───────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
BENCHMARKING_RADIUS_METERS=5000

# ── Email (choose one) ─────────────────────────────────────────────────────
# Option A — Resend (recommended, free 3000 emails/month): resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
APP_NAME=MarketPilot

# Option B — Gmail SMTP (use an App Password, not your real password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=your@gmail.com

# ── CORS (comma-separated list of allowed frontend origins) ────────────────
# Set this to your Firebase Hosting URL after deploying
CORS_ORIGINS=https://YOUR_PROJECT_ID.web.app,https://YOUR_CUSTOM_DOMAIN.com

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_URL=https://YOUR_PROJECT_ID.web.app
